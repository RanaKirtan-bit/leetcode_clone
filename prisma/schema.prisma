generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url = env("DATABASE_URL")
}

enum UserRole {
  ADMIN 
  USER
}

model User {
  id Int @id  @default (autoincrement())
  clerkId String @unique
  email String @unique
  role UserRole @default(USER)
  firstname String?
  lastname String?
  imageUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}